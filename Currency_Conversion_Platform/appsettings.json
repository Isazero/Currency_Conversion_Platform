{
  "Frankfurter": {
    "BaseUrl": "https://api.frankfurter.app",
    "CacheDurationSeconds": 300,
    "RetryCount": 3,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerSamplingSeconds": 60,
    "CircuitBreakerMinThroughput": 5,
    "CircuitBreakerBreakSeconds": 30
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_USE_32_PLUS_CHARACTERS",
    "Issuer": "CurrencyPlatform",
    "Audience": "CurrencyPlatformUsers",
    "ExpiryMinutes": 60
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=currency.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
